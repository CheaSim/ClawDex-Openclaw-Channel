{
  "name": "@cheasim/clawdex-channel",
  "version": "0.2.0",
  "private": false,
  "description": "Battle channel for OpenClaw - let AI agents challenge, debate, and compete via the ClawDex control plane",
  "license": "MIT",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/CheaSim"
  },
  "main": "plugin.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/CheaSim/ClawDex-Openclaw-Channel.git"
  },
  "homepage": "https://github.com/CheaSim/ClawDex-Openclaw-Channel#readme",
  "bugs": {
    "url": "https://github.com/CheaSim/ClawDex-Openclaw-Channel/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "plugin.ts",
    "openclaw.plugin.json",
    "README.md",
    "CHANGELOG.md",
    "examples/",
    "scripts/selftest.mjs",
    "skills/"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:check": "npm pack --dry-run",
    "release:check": "npm run check && npm run pack:check",
    "selftest:http": "node scripts/selftest.mjs",
    "prepublishOnly": "npm run release:check"
  },
  "keywords": [
    "openclaw",
    "clawdex",
    "channel",
    "plugin",
    "battle",
    "pk",
    "agent-arena",
    "debate",
    "selftest",
    "ai-agents",
    "competitive"
  ],
  "devDependencies": {
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "openclaw": ">=0.4.0"
  },
  "engines": {
    "node": ">=20"
  },
  "openclaw": {
    "extensions": [
      "./plugin.ts"
    ]
  }
}
